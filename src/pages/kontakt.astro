---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Kontakt" description="Kontakt, Adresse und Anfahrt zur Praxis van Dinther in Krefeld. Neukirchener Straße 5.">

  <section class="max-w-6xl mx-auto px-6 py-24">
    <p class="text-sm font-semibold tracking-widest uppercase text-[#0071E3] mb-4">Kontakt</p>
    <h1 class="text-5xl font-semibold tracking-tight text-[#1D1D1F] mb-16">So erreichen Sie uns.</h1>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 mb-16">
      <!-- Kontaktdaten -->
      <div>
        <div class="bg-[#F5F5F7] rounded-2xl p-10 mb-6">
          <p class="text-xs font-semibold tracking-widest uppercase text-[#86868B] mb-6">Adresse & Kontakt</p>
          <div class="space-y-4">
            <div>
              <p class="text-base font-medium text-[#1D1D1F]">Praxis van Dinther</p>
              <p class="text-base text-[#6E6E73]">Neukirchener Straße 5<br />47829 Krefeld</p>
            </div>
            <div class="border-t border-[#E8E8ED] pt-4 space-y-2">
              <p class="text-base text-[#6E6E73]">Tel: <a href="tel:021514789890" class="text-[#1D1D1F] hover:text-[#0071E3]">02151 478989</a></p>
              <p class="text-base text-[#6E6E73]">Fax: 02151 475594</p>
              <p class="text-base text-[#6E6E73]">Rezept-Hotline: <a href="tel:021515350714" class="text-[#1D1D1F] hover:text-[#0071E3]">02151 5350714</a></p>
              <p class="text-base text-[#6E6E73]">E-Mail: <a href="mailto:info@praxis-vandinther.de" class="text-[#0071E3] hover:underline">info@praxis-vandinther.de</a></p>
            </div>
          </div>
        </div>

        <div class="bg-[#F5F5F7] rounded-2xl p-8">
          <p class="text-xs font-semibold tracking-widest uppercase text-[#86868B] mb-4">ÖPNV-Anfahrt</p>
          <p class="text-base text-[#6E6E73]">Straßenbahn Linie 042 oder Bus Linie 058</p>
          <p class="text-base text-[#1D1D1F] font-medium mt-1">Haltestelle: Neukirchener Straße</p>
        </div>
      </div>

      <!-- Rezepte / Befunde -->
      <div class="space-y-6">
        <div class="bg-[#FFF9EB] border border-[#F59E0B] rounded-2xl p-8">
          <div class="flex gap-3 mb-4">
            <svg class="text-[#F59E0B] shrink-0 mt-0.5" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3"/><path d="M12 9v4"/><path d="M12 17h.01"/></svg>
            <p class="text-sm font-semibold text-[#92400E]">Atemwegsinfekt-Sprechstunde</p>
          </div>
          <p class="text-sm text-[#92400E] leading-relaxed">
            Bei Symptomen wie Husten, Schnupfen, Fieber oder Gliederschmerzen kommen Sie bitte <strong>ausschließlich Mo–Do von 11–12 Uhr</strong> mit FFP2-Maske. Kein Termin erforderlich.
          </p>
        </div>

        <div class="bg-[#F5F5F7] rounded-2xl p-8 space-y-4">
          <p class="text-xs font-semibold tracking-widest uppercase text-[#86868B]">Befunde & Rezepte</p>
          <div class="space-y-3">
            <div class="flex gap-3">
              <span class="text-[#0071E3] font-semibold shrink-0">→</span>
              <p class="text-sm text-[#6E6E73]"><strong class="text-[#1D1D1F]">Befunde</strong> nur über Videosprechstunde per Doctolib (nicht per Telefon)</p>
            </div>
            <div class="flex gap-3">
              <span class="text-[#0071E3] font-semibold shrink-0">→</span>
              <p class="text-sm text-[#6E6E73]"><strong class="text-[#1D1D1F]">Rezepte & Überweisungen</strong> über das Kontaktformular oder Rezept-Hotline: 02151 5350714</p>
            </div>
            <div class="flex gap-3">
              <span class="text-[#0071E3] font-semibold shrink-0">→</span>
              <p class="text-sm text-[#6E6E73]"><strong class="text-[#1D1D1F]">Terminbuchung</strong> ausschließlich über Doctolib</p>
            </div>
          </div>
        </div>

        <div class="bg-[#FEF2F2] border border-[#EF4444] rounded-2xl p-6">
          <p class="text-sm font-semibold text-[#991B1B] mb-2">Notfall</p>
          <p class="text-sm text-[#991B1B]">Bereitschaftsdienst: <strong>116 117</strong> · Notarzt: <strong>112</strong></p>
        </div>
      </div>
    </div>

    <!-- Kontaktformular -->
    <div class="border-t border-[#E8E8ED] pt-16">
      <h2 class="text-3xl font-semibold tracking-tight text-[#1D1D1F] mb-4">Kontaktformular</h2>
      <p class="text-base text-[#6E6E73] mb-8 max-w-lg">
        Für Rezeptanfragen, Überweisungen, Neupatientenanfragen und sonstige Anliegen.
      </p>

      <div id="form-success" class="hidden mb-6 bg-[#F0FDF4] border border-[#86EFAC] rounded-2xl p-6">
        <p class="text-base font-medium text-[#166534]">✓ Ihre Nachricht wurde erfolgreich gesendet. Wir melden uns so bald wie möglich.</p>
      </div>
      <div id="form-error" class="hidden mb-6 bg-[#FEF2F2] border border-[#FECACA] rounded-2xl p-6">
        <p id="form-error-msg" class="text-base font-medium text-[#991B1B]"></p>
      </div>

      <form id="contact-form" method="POST" action="/api/contact" class="max-w-xl space-y-5">

        <!-- Honeypot -->
        <input type="text" name="website" class="hidden" tabindex="-1" autocomplete="off" />

        <div>
          <label for="name" class="block text-sm font-medium text-[#1D1D1F] mb-1.5">Name <span class="text-[#922c37]">*</span></label>
          <input
            type="text" id="name" name="name" required autocomplete="name"
            class="w-full rounded-xl border border-[#E8E8ED] bg-[#F5F5F7] px-4 py-3 text-base text-[#1D1D1F] placeholder:text-[#86868B] focus:outline-none focus:border-[#922c37] focus:ring-2 focus:ring-[#922c37]/20 transition"
            placeholder="Vor- und Nachname"
          />
        </div>

        <div>
          <label for="email" class="block text-sm font-medium text-[#1D1D1F] mb-1.5">E-Mail <span class="text-[#922c37]">*</span></label>
          <input
            type="email" id="email" name="email" required autocomplete="email"
            class="w-full rounded-xl border border-[#E8E8ED] bg-[#F5F5F7] px-4 py-3 text-base text-[#1D1D1F] placeholder:text-[#86868B] focus:outline-none focus:border-[#922c37] focus:ring-2 focus:ring-[#922c37]/20 transition"
            placeholder="ihre@email.de"
          />
        </div>

        <div>
          <label for="phone" class="block text-sm font-medium text-[#1D1D1F] mb-1.5">Telefon <span class="text-[#86868B] font-normal">(optional)</span></label>
          <input
            type="tel" id="phone" name="phone" autocomplete="tel"
            class="w-full rounded-xl border border-[#E8E8ED] bg-[#F5F5F7] px-4 py-3 text-base text-[#1D1D1F] placeholder:text-[#86868B] focus:outline-none focus:border-[#922c37] focus:ring-2 focus:ring-[#922c37]/20 transition"
            placeholder="02151 …"
          />
        </div>

        <div>
          <label for="message" class="block text-sm font-medium text-[#1D1D1F] mb-1.5">Nachricht <span class="text-[#922c37]">*</span></label>
          <textarea
            id="message" name="message" required rows="5"
            class="w-full rounded-xl border border-[#E8E8ED] bg-[#F5F5F7] px-4 py-3 text-base text-[#1D1D1F] placeholder:text-[#86868B] focus:outline-none focus:border-[#922c37] focus:ring-2 focus:ring-[#922c37]/20 transition resize-none"
            placeholder="Ihr Anliegen …"
          ></textarea>
        </div>

        <button
          type="submit" id="submit-btn"
          class="inline-flex items-center justify-center rounded-full px-8 py-3.5 text-base font-medium text-white transition-colors"
          style="background:#922c37;"
          onmouseover="this.style.background='#7a2430'" onmouseout="this.style.background='#922c37'"
        >
          Nachricht senden
        </button>
      </form>
    </div>
  </section>

  <script>
    const form = document.getElementById('contact-form') as HTMLFormElement;
    const btn  = document.getElementById('submit-btn') as HTMLButtonElement;
    const successBox = document.getElementById('form-success')!;
    const errorBox   = document.getElementById('form-error')!;
    const errorMsg   = document.getElementById('form-error-msg')!;

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      btn.disabled = true;
      btn.textContent = 'Wird gesendet …';
      successBox.classList.add('hidden');
      errorBox.classList.add('hidden');

      try {
        const res = await fetch('/api/contact', { method: 'POST', body: new FormData(form) });
        const json = await res.json();
        if (res.ok) {
          form.reset();
          successBox.classList.remove('hidden');
          successBox.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        } else {
          errorMsg.textContent = json.error || 'Ein Fehler ist aufgetreten.';
          errorBox.classList.remove('hidden');
        }
      } catch {
        errorMsg.textContent = 'Verbindungsfehler. Bitte versuchen Sie es erneut.';
        errorBox.classList.remove('hidden');
      } finally {
        btn.disabled = false;
        btn.textContent = 'Nachricht senden';
      }
    });
  </script>

</BaseLayout>
