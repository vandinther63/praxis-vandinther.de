---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Leistungsspektrum" description="Diagnostik, Vorsorge, kassenärztliche Behandlungen und IGeL-Leistungen der Praxis van Dinther in Krefeld.">

  <section class="max-w-6xl mx-auto px-6 py-24">
    <p class="text-sm font-semibold tracking-widest uppercase text-[#0071E3] mb-4">Leistungen</p>
    <h1 class="text-5xl font-semibold tracking-tight text-[#1D1D1F] mb-6">Leistungsspektrum.</h1>
    <p class="text-lg text-[#6E6E73] max-w-xl leading-relaxed mb-20">
      Von Vorsorge und Diagnostik bis zu individuellen Gesundheitsleistungen — alles aus einer Hand.
    </p>

    <!-- Diagnostik -->
    <div id="diagnostik" class="mb-20">
      <h2 class="text-3xl font-semibold tracking-tight text-[#1D1D1F] mb-8">Diagnostik</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        {[
          'Blutuntersuchungen (Labor)',
          'EKG und Belastungs-EKG (Ergometrie)',
          'Langzeitblutdruckmessung',
          'Lungenfunktionstest',
          'Ultraschall Schilddrüse',
          'Ultraschall Abdomen & Thorax',
        ].map(item => (
          <div class="bg-[#F5F5F7] rounded-xl px-6 py-4 text-base text-[#1D1D1F]">{item}</div>
        ))}
      </div>
    </div>

    <!-- Vorsorge -->
    <div id="vorsorge" class="border-t border-[#E8E8ED] pt-16 mb-20">
      <h2 class="text-3xl font-semibold tracking-tight text-[#1D1D1F] mb-8">Vorsorgeuntersuchungen</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-3 max-w-3xl">
        {[
          'Prostatakrebsvorsorge ab 45',
          'Darmkrebsvorsorge ab 45 / Früherkennung ab 50',
          'Krebsnachsorge',
          'Gesundheitscheck (Check-up 35) alle 3 Jahre',
          'Hautkrebsscreening ab 18 Jahren',
          'Früherkennung Bauchaortenaneurysma',
          'Jugendgesundheitsuntersuchungen',
          'Geriatrisches Basisassessment',
          'Demenz-Früherkennungstests',
        ].map(item => (
          <div class="flex items-start gap-3 py-3 border-b border-[#E8E8ED]">
            <div class="w-1.5 h-1.5 rounded-full bg-[#0071E3] shrink-0 mt-2"></div>
            <p class="text-base text-[#6E6E73]">{item}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- Kassenleistungen -->
    <div class="border-t border-[#E8E8ED] pt-16 mb-20">
      <h2 class="text-3xl font-semibold tracking-tight text-[#1D1D1F] mb-8">Kassenmedizinische Behandlungen</h2>
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
        {[
          'Impfungen (STIKO)',
          'Chirotherapie',
          'Psychosomatische Grundversorgung',
          'Kleine Chirurgie',
          'Wärmebehandlungen',
          'Elektrotherapie',
          'Inhalationen',
        ].map(item => (
          <div class="bg-[#F5F5F7] rounded-xl px-5 py-4 text-sm text-[#1D1D1F]">{item}</div>
        ))}
      </div>
    </div>

    <!-- DMP -->
    <div class="border-t border-[#E8E8ED] pt-16 mb-20">
      <h2 class="text-3xl font-semibold tracking-tight text-[#1D1D1F] mb-3">Disease-Management-Programme</h2>
      <p class="text-base text-[#6E6E73] mb-8">Strukturierte Betreuung chronischer Erkrankungen.</p>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        {[
          { label: 'Diabetes mellitus', sub: 'Typ 2' },
          { label: 'Koronare Herzerkrankung', sub: 'KHK' },
          { label: 'Asthma bronchiale', sub: '' },
          { label: 'COPD', sub: 'Chron. Lungenerkrankung' },
        ].map(item => (
          <div class="bg-[#F5F5F7] rounded-2xl p-6">
            <p class="text-base font-medium text-[#1D1D1F]">{item.label}</p>
            {item.sub && <p class="text-sm text-[#86868B] mt-1">{item.sub}</p>}
          </div>
        ))}
      </div>
    </div>

    <!-- IGeL -->
    <div id="igel" class="border-t border-[#E8E8ED] pt-16">
      <h2 class="text-3xl font-semibold tracking-tight text-[#1D1D1F] mb-3">Individuelle Gesundheitsleistungen</h2>
      <p class="text-base text-[#6E6E73] mb-8">Selbstzahlerleistungen, abgerechnet nach GOÄ.</p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-3 max-w-3xl mb-10">
        {[
          'Erweiterter jährlicher Gesundheitscheck',
          'Erweiterte Blutuntersuchungen',
          'PSA-Bestimmung',
          'Blutgruppenbestimmung',
          'Ultraschalluntersuchungen auf Wunsch',
          'Infusionen & Aufbauspritzen',
          'Atteste (Reiserücktritt, Schule, Sport)',
          'Kinesio Taping',
          'Sporttauglichkeitsuntersuchungen',
          'Tauchsportuntersuchungen',
          'Reisemedizinische Beratung & Reiseimpfung',
        ].map(item => (
          <div class="flex items-start gap-3 py-3 border-b border-[#E8E8ED]">
            <div class="w-1.5 h-1.5 rounded-full bg-[#0071E3] shrink-0 mt-2"></div>
            <p class="text-base text-[#6E6E73]">{item}</p>
          </div>
        ))}
      </div>
      <a href="/#kontakt" class="inline-flex items-center bg-[#F5F5F7] text-[#1D1D1F] rounded-full px-8 py-3.5 text-base font-medium hover:bg-[#E8E8ED] transition-colors">
        Fragen zu Leistungen? Kontakt aufnehmen →
      </a>
    </div>
  </section>

</BaseLayout>
