---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Stellenangebote" description="Aktuelle Stellenangebote der Praxis van Dinther in Krefeld.">

  <section class="max-w-6xl mx-auto px-6 py-24">
    <p class="text-sm font-semibold tracking-widest uppercase text-[#0071E3] mb-4">Karriere</p>
    <h1 class="text-5xl font-semibold tracking-tight text-[#1D1D1F] mb-6">Stellenangebote.</h1>

    <div class="max-w-xl mt-16 bg-[#F5F5F7] rounded-2xl p-10">
      <p class="text-2xl font-semibold tracking-tight text-[#1D1D1F] mb-4">Aktuell keine offenen Stellen.</p>
      <p class="text-base text-[#6E6E73] leading-relaxed mb-8">
        Wir freuen uns jedoch jederzeit über Initiativbewerbungen engagierter Medizinischer Fachangestellter.
      </p>
      <a href="mailto:info@praxis-vandinther.de" class="inline-flex items-center bg-[#0071E3] text-white rounded-full px-8 py-3.5 text-base font-medium hover:bg-[#0058B0] transition-colors">
        Initiativ bewerben →
      </a>
    </div>
  </section>

</BaseLayout>
