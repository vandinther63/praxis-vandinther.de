---
import BaseLayout from '../../layouts/BaseLayout.astro';

const werdegang = [
  { jahr: '2014', text: 'Lehrbeauftragter des Instituts für Allgemeinmedizin (IFAM) der Heinrich-Heine-Universität Düsseldorf' },
  { jahr: '2014', text: 'Akademische Lehrpraxis des IFAM der Heinrich-Heine-Universität Düsseldorf' },
  { jahr: '2020', text: 'Akademische Lehrpraxis des IFAM für das Praktische Jahr' },
  { jahr: '2003', text: 'Niedergelassen in eigener Praxis in Krefeld' },
  { jahr: '2002', text: 'Facharzt für Allgemeinmedizin' },
  { jahr: '1997', text: 'Approbation als Arzt' },
  { jahr: '1995', text: 'Dritter Abschnitt der Ärztlichen Prüfung, Arzt im Praktikum' },
  { jahr: 'ab 1989', text: 'Medizinstudium an der Heinrich-Heine-Universität Düsseldorf' },
];

const stationen = [
  { ort: 'Sana-Klinikum Remscheid, Medizinische Klinik II', detail: 'Internistische Ausbildung · Prof. Dr. H. Menge' },
  { ort: 'Sana-Klinikum Remscheid, Radiologie & Nuklearmedizin', detail: 'Radiologische Ausbildung · Dr. G. Meindl' },
  { ort: 'Sana-Krankenhaus Hürth, Viszeral- & Unfallchirurgie', detail: 'Allgemein- & unfallchirurgische Ausbildung · Dr. W. R. Dingels' },
  { ort: 'Praxis Dr. M. Müschen, Neuss', detail: 'Allgemeinmedizinische Ausbildung' },
  { ort: 'Werksärztlicher Dienst Mercedes-Benz AG, Düsseldorf', detail: 'Arbeitsmedizin · Dr. Kalkowski' },
];

const weiterbildungen = [
  'Psychosomatische Grundversorgung',
  'Manuelle Therapie (Chirotherapie)',
  'Fachkunde Arzt im Rettungsdienst',
  'Fachkunde Röntgendiagnostik',
  'Sonographie Schilddrüse, Thorax & Abdomen (KBV-Richtlinien)',
];

const mitgliedschaften = [
  'Deutsche Gesellschaft für Allgemein- und Familienmedizin (DEGAM)',
  'Deutsche Gesellschaft für Sportmedizin und Prävention (DGSP)',
  'Deutsche Gesellschaft für Manuelle Medizin (DGMM)',
];
---

<BaseLayout title="Frank van Dinther — Vita" description="Werdegang und Qualifikationen von Frank van Dinther, Facharzt für Allgemeinmedizin in Krefeld.">

  <section class="max-w-4xl mx-auto px-6 pt-32 pb-24">
    <a href="/#team" class="inline-flex items-center gap-1.5 text-sm text-[#6E6E73] hover:text-[#1D1D1F] transition-colors mb-10">
      <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
      Zurück zum Team
    </a>

    <!-- Kopf -->
    <div class="flex flex-col sm:flex-row items-center sm:items-end gap-8 mb-16">
      <img
        src="/team/frank-van-dinther.jpg"
        alt="Frank van Dinther"
        width="160"
        height="160"
        class="w-40 h-40 rounded-full object-cover shrink-0 ring-1 ring-[#E8E8ED]"
      />
      <div class="text-center sm:text-left">
        <p class="text-sm font-semibold tracking-widest uppercase text-[#922c37] mb-3">Vita</p>
        <h1 class="text-4xl lg:text-5xl font-semibold tracking-tight text-[#1D1D1F] leading-tight">Frank van Dinther</h1>
        <p class="text-lg text-[#6E6E73] mt-2">Facharzt für Allgemeinmedizin · Krefeld</p>
      </div>
    </div>

    <!-- Werdegang als Timeline -->
    <div class="mb-16">
      <h2 class="text-sm font-semibold tracking-widest uppercase text-[#86868B] mb-8">Werdegang</h2>
      <div class="space-y-0">
        {werdegang.map(e => (
          <div class="grid grid-cols-[5rem_1fr] sm:grid-cols-[8rem_1fr] gap-4 sm:gap-8 py-4 border-b border-[#E8E8ED]">
            <span class="text-sm font-medium text-[#922c37] tabular-nums">{e.jahr}</span>
            <span class="text-[15px] text-[#1D1D1F] leading-snug">{e.text}</span>
          </div>
        ))}
      </div>
    </div>

    <!-- Ausbildungsstationen -->
    <div class="mb-16">
      <h2 class="text-sm font-semibold tracking-widest uppercase text-[#86868B] mb-8">Ausbildungsstationen</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {stationen.map(s => (
          <div class="bg-[#F5F5F7] rounded-2xl p-6">
            <p class="text-sm font-medium text-[#1D1D1F] leading-snug">{s.ort}</p>
            <p class="text-xs text-[#86868B] mt-1.5">{s.detail}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- Wissenschaft -->
    <div class="mb-16">
      <h2 class="text-sm font-semibold tracking-widest uppercase text-[#86868B] mb-8">Wissenschaftliche Arbeit</h2>
      <div class="bg-[#F5F5F7] rounded-2xl p-8">
        <p class="text-[15px] text-[#1D1D1F] leading-relaxed">
          Experimentelle wissenschaftliche Arbeit am Institut für experimentelle Chirurgie der Heinrich-Heine-Universität (Leitung Prof. Dr. G. Arnold) — Thema: <em>Wirkung von Calciumsensitizern an „gestunntem" Myokard</em>.
        </p>
        <p class="text-sm text-[#6E6E73] leading-relaxed mt-4">
          Mitveröffentlichung auf dem 2nd International Symposium On Heart Failure, Genf, 16.–20. Mai 1993: <em>Disturbed O₂-utilization of the contractile apparatus in stunned myocardium</em>.
        </p>
      </div>
    </div>

    <!-- Weiterbildungen + Mitgliedschaften -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
      <div>
        <h2 class="text-sm font-semibold tracking-widest uppercase text-[#86868B] mb-6">Weiterbildungen</h2>
        <ul class="space-y-3">
          {weiterbildungen.map(w => (
            <li class="flex items-start gap-3 text-[15px] text-[#1D1D1F]">
              <span class="w-1.5 h-1.5 rounded-full bg-[#922c37] shrink-0 mt-2"></span>{w}
            </li>
          ))}
        </ul>
      </div>
      <div>
        <h2 class="text-sm font-semibold tracking-widest uppercase text-[#86868B] mb-6">Mitgliedschaften</h2>
        <ul class="space-y-3">
          {mitgliedschaften.map(m => (
            <li class="flex items-start gap-3 text-[15px] text-[#1D1D1F]">
              <span class="w-1.5 h-1.5 rounded-full bg-[#922c37] shrink-0 mt-2"></span>{m}
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- CTA -->
    <div class="mt-16 pt-10 border-t border-[#E8E8ED] flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
      <p class="text-base text-[#6E6E73]">Termin bei Frank van Dinther?</p>
      <a
        href="https://www.doctolib.de/allgemeinarzt/krefeld/frank-van-dinther"
        target="_blank"
        rel="noopener"
        class="inline-flex items-center bg-[#922c37] text-white rounded-full px-8 py-3.5 text-base font-medium hover:bg-[#7a2430] transition-colors"
      >
        Termin online buchen
      </a>
    </div>
  </section>

</BaseLayout>
