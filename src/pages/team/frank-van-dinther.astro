---
import BaseLayout from '../../layouts/BaseLayout.astro';

const weiterbildungen = [
  'Psychosomatische Grundversorgung',
  'Manuelle Therapie (Chirotherapie)',
  'Fachkunde Arzt im Rettungsdienst',
  'Fachkunde Röntgendiagnostik',
  'Sonographie Schilddrüse, Thorax & Abdomen (KBV)',
];

const mitgliedschaften = [
  'Deutsche Gesellschaft für Allgemein- und Familienmedizin (DEGAM)',
  'Deutsche Gesellschaft für Sportmedizin und Prävention (DGSP)',
  'Deutsche Gesellschaft für Manuelle Medizin (DGMM)',
];

const stationen = [
  { jahr: '1979', titel: 'Maschinenschlosser', text: 'Ausbildung im Siemens-Turbinenwerk Wesel — der Start ins Berufsleben, lange vor der Medizin.' },
  { jahr: '1988', titel: 'Abitur, zweiter Bildungsweg', text: 'Allgemeine Hochschulreife am Erzbischöflichen Friedrich-Spee-Kolleg in Neuss.' },
  { jahr: '1989', titel: 'Medizinstudium', text: 'Studium der Humanmedizin an der Heinrich-Heine-Universität Düsseldorf.' },
  { jahr: '1997', titel: 'Approbation als Arzt', text: 'Nach dem Studium und der Zeit als Arzt im Praktikum die Zulassung zum Arztberuf.' },
  { jahr: '2002', titel: 'Facharzt für Allgemeinmedizin', text: 'Abschluss der Facharztweiterbildung — mit Stationen in Innerer Medizin, Radiologie, Chirurgie und Arbeitsmedizin.' },
  { jahr: '2003', titel: 'Eigene Praxis in Krefeld', text: 'Niederlassung in eigener Hausarztpraxis — seither die feste Anlaufstelle für Familien in Krefeld.' },
  { jahr: '2014', titel: 'Lehrarzt der HHU Düsseldorf', text: 'Akademische Lehrpraxis und Lehrbeauftragter des Instituts für Allgemeinmedizin — Ausbildung des ärztlichen Nachwuchses.' },
];
---

<BaseLayout title="Frank van Dinther — Vita" description="Der Werdegang von Frank van Dinther, Facharzt für Allgemeinmedizin in Krefeld — vom Maschinenschlosser zum Hausarzt und Lehrarzt.">

  <!-- Kopf -->
  <header class="max-w-6xl mx-auto px-6 pt-36 lg:pt-44 pb-16">
    <a href="/#team" class="inline-flex items-center gap-1.5 text-sm text-[#6E6E73] hover:text-[#1D1D1F] transition-colors mb-12">
      <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
      Zurück zum Team
    </a>

    <div class="flex flex-col sm:flex-row items-start sm:items-end gap-8">
      <img
        src="/team/frank-van-dinther.jpg"
        alt="Frank van Dinther"
        width="160"
        height="160"
        class="w-36 h-36 lg:w-40 lg:h-40 rounded-full object-cover ring-1 ring-[#E8E8ED] shrink-0"
      />
      <div>
        <p class="text-sm font-semibold tracking-widest uppercase text-[#922c37] mb-3">Vita</p>
        <h1 class="text-4xl lg:text-6xl font-semibold tracking-tight text-[#1D1D1F] leading-[1.05]">
          Frank van Dinther
        </h1>
        <p class="text-lg lg:text-xl text-[#6E6E73] mt-3">
          Facharzt für Allgemeinmedizin · Ihr Hausarzt in Krefeld
        </p>
      </div>
    </div>
  </header>

  <!-- Erzähltext -->
  <article class="max-w-6xl mx-auto px-6 pb-8">
    <div class="space-y-7 text-lg text-[#1D1D1F] leading-[1.75]">
      <p class="text-2xl lg:text-3xl font-medium tracking-tight leading-snug text-[#1D1D1F]">
        Nicht jeder Arzt beginnt seinen Weg im Hörsaal. Frank van Dinther begann ihn an der Werkbank.
      </p>
      <p>
        Bevor die Medizin kam, lernte er das Handwerk: Nach der Mittleren Reife in Rees absolvierte er eine Ausbildung zum Maschinenschlosser im Siemens-Turbinenwerk Wesel. Erst danach, über den zweiten Bildungsweg, kam das Abitur — und mit ihm die Entscheidung, Arzt zu werden. 1989 nahm er das Medizinstudium an der Heinrich-Heine-Universität Düsseldorf auf.
      </p>
      <p>
        Diese Herkunft prägt bis heute, wie er arbeitet: bodenständig, gründlich, mit dem Blick für das Ganze statt nur für das Symptom. 1997 folgte die Approbation, 2002 der Facharzt für Allgemeinmedizin. Seit April 2003 führt er seine eigene Hausarztpraxis in Krefeld — inzwischen seit über zwanzig Jahren für dieselben Familien, oft über Generationen hinweg.
      </p>
      <p>
        Auf dem Weg dorthin sammelte er breite klinische Erfahrung: Innere Medizin und Radiologie am Sana-Klinikum Remscheid, Allgemein- und Unfallchirurgie am Sana-Krankenhaus Hürth, Allgemeinmedizin in der Praxis Dr. Müschen in Neuss und Arbeitsmedizin im werksärztlichen Dienst von Mercedes-Benz in Düsseldorf. Schon während des Studiums forschte er am Institut für experimentelle Chirurgie der HHU über die Funktion des Herzmuskels — eine Arbeit, die 1993 auf einem internationalen Symposium in Genf vorgestellt wurde.
      </p>
      <p>
        Was ihm besonders am Herzen liegt, ist die Ausbildung zukünftiger Kollegen. Seit 2014 ist seine Praxis Akademische Lehrpraxis der Heinrich-Heine-Universität, seit 2020 auch für das Praktische Jahr. Als Lehrbeauftragter des Instituts für Allgemeinmedizin begleitet er angehende Ärztinnen und Ärzte auf ihrem Weg — und bildet als Weiterbildungsbefugter den ärztlichen Nachwuchs in der Allgemeinmedizin aus.
      </p>
    </div>
  </article>

  <!-- Interaktive Timeline — in einer Card -->
  <section class="max-w-6xl mx-auto px-6 py-16">
    <div id="timeline" class="bg-[#F5F5F7] rounded-3xl p-8 lg:p-12">
      <!-- Marker-Reihe (pt-3 = Headroom, damit der aktive Punkt beim Vergrößern nicht abgeschnitten wird) -->
      <div class="tl-scroll overflow-x-auto pt-3 pb-3 -mx-8 px-8 lg:-mx-12 lg:px-12">
        <div class="tl-row relative flex gap-12 sm:gap-0 sm:justify-between min-w-max sm:min-w-0">
          <div class="absolute left-[9px] right-[9px] top-[9px] h-[2px] bg-[#E3DADB] rounded-full"></div>
          <div id="tl-fill" class="absolute left-[9px] top-[9px] h-[2px] bg-[#922c37] rounded-full transition-all duration-300" style="width:0"></div>
          {stationen.map((s, i) => (
            <button type="button" class="tl-marker group relative z-10 flex flex-col items-center gap-3 shrink-0 cursor-pointer" data-i={i} aria-label={s.jahr + ' — ' + s.titel}>
              <span class="tl-dot block w-[18px] h-[18px] rounded-full bg-white border-2 border-[#D8CBCD] transition-all duration-200"></span>
              <span class="tl-year text-sm font-medium text-[#86868B] tabular-nums whitespace-nowrap transition-colors duration-200">{s.jahr}</span>
            </button>
          ))}
        </div>
      </div>

      <!-- Detail — fixe Höhe, mit Verbinder zum aktiven Punkt -->
      <div id="tl-detail" class="mt-8 relative bg-white rounded-2xl p-8 lg:p-10 flex flex-col justify-center">
        <!-- Tropfen-Linie vom aktiven Punkt herunter -->
        <span id="tl-connector" class="absolute -top-8 w-[2px] h-8 bg-[#922c37] hidden sm:block" style="left:0;transition:left 300ms var(--ease-out)"></span>
        <!-- Sprechblasen-Spitze (Notch), wandert mit dem aktiven Jahr -->
        <span id="tl-caret" class="absolute -top-[7px] w-[14px] h-[14px] bg-white rotate-45 rounded-[2px] hidden sm:block" style="left:0;transition:left 300ms var(--ease-out)"></span>
        <p id="tl-title" class="text-xl lg:text-2xl font-semibold text-[#1D1D1F] tracking-tight"></p>
        <p id="tl-text" class="text-[15px] lg:text-base text-[#6E6E73] mt-3 leading-relaxed"></p>
      </div>
    </div>
  </section>

  <!-- Auf einen Blick — sekundär, faktisch -->
  <section class="max-w-6xl mx-auto px-6 py-16">
    <div class="bg-[#F5F5F7] rounded-3xl p-8 lg:p-12">
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-10">
        <div>
          <h2 class="text-xs font-semibold tracking-widest uppercase text-[#86868B] mb-5">Schwerpunkte & Fachkunde</h2>
          <ul class="space-y-3">
            {weiterbildungen.map(w => (
              <li class="flex items-start gap-3 text-[15px] text-[#1D1D1F] leading-snug">
                <span class="w-1.5 h-1.5 rounded-full bg-[#922c37] shrink-0 mt-2"></span>{w}
              </li>
            ))}
          </ul>
        </div>
        <div>
          <h2 class="text-xs font-semibold tracking-widest uppercase text-[#86868B] mb-5">Mitgliedschaften</h2>
          <ul class="space-y-3">
            {mitgliedschaften.map(m => (
              <li class="flex items-start gap-3 text-[15px] text-[#1D1D1F] leading-snug">
                <span class="w-1.5 h-1.5 rounded-full bg-[#922c37] shrink-0 mt-2"></span>{m}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="max-w-6xl mx-auto px-6 pb-28">
    <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-5">
      <p class="text-lg text-[#1D1D1F]">Lernen Sie Frank van Dinther kennen.</p>
      <a
        href="https://www.doctolib.de/allgemeinarzt/krefeld/frank-van-dinther"
        target="_blank"
        rel="noopener"
        class="inline-flex items-center bg-[#922c37] text-white rounded-full px-8 py-3.5 text-base font-medium hover:bg-[#7a2430] transition-colors"
      >
        Termin online buchen
      </a>
    </div>
  </section>

  <style>
    .tl-marker[data-active] .tl-dot {
      background: #922c37;
      border-color: #922c37;
      transform: scale(1.3);
    }
    .tl-marker[data-active] .tl-year { color: #1D1D1F; font-weight: 600; }
    .tl-marker:hover .tl-dot { border-color: #922c37; }
    #tl-title, #tl-text { transition: opacity 180ms var(--ease-out), filter 180ms var(--ease-out); }
    #timeline.is-switching #tl-title,
    #timeline.is-switching #tl-text { opacity: 0; filter: blur(2px); }
  </style>

  <script define:vars={{ stationen }}>
    (function () {
      const tl = document.getElementById('timeline');
      if (!tl) return;
      const markers = Array.from(tl.querySelectorAll('.tl-marker'));
      const titleEl = document.getElementById('tl-title');
      const textEl = document.getElementById('tl-text');
      const fill = document.getElementById('tl-fill');
      const row = tl.querySelector('.tl-row');
      const detail = document.getElementById('tl-detail');
      const connector = document.getElementById('tl-connector');
      const caret = document.getElementById('tl-caret');
      let active = -1;

      function updateFill(i) {
        if (!fill || !row) return;
        const dot = markers[i].querySelector('.tl-dot');
        const rowBox = row.getBoundingClientRect();
        const dotBox = dot.getBoundingClientRect();
        const center = dotBox.left + dotBox.width / 2 - rowBox.left;
        fill.style.width = Math.max(0, center - 9) + 'px';
      }

      // Verbinder + Notch unter den aktiven Punkt schieben
      function updateConnector(i) {
        if (!detail || !connector || !caret) return;
        const dot = markers[i].querySelector('.tl-dot');
        const dBox = detail.getBoundingClientRect();
        const dotBox = dot.getBoundingClientRect();
        let center = dotBox.left + dotBox.width / 2 - dBox.left;
        center = Math.max(20, Math.min(dBox.width - 20, center)); // im Kartenrand halten
        connector.style.left = (center - 1) + 'px';
        caret.style.left = (center - 7) + 'px';
      }

      // Höhe einmalig auf den längsten Eintrag fixieren -> kein Springen
      function lockHeight() {
        if (!detail) return;
        detail.style.height = 'auto';
        let max = 0;
        stationen.forEach(s => {
          titleEl.textContent = s.jahr + ' · ' + s.titel;
          textEl.textContent = s.text;
          max = Math.max(max, detail.offsetHeight);
        });
        detail.style.height = max + 'px';
      }

      function show(i) {
        if (i === active) return;
        active = i;
        markers.forEach((m, idx) => {
          if (idx === i) m.setAttribute('data-active', '');
          else m.removeAttribute('data-active');
        });
        updateFill(i);
        updateConnector(i);
        // sanfter Crossfade (Emil: blur überbrückt den Statewechsel)
        tl.classList.add('is-switching');
        setTimeout(() => {
          titleEl.textContent = stationen[i].jahr + ' · ' + stationen[i].titel;
          textEl.textContent = stationen[i].text;
          tl.classList.remove('is-switching');
        }, 130);
      }

      markers.forEach((m, i) => {
        m.addEventListener('mouseenter', () => show(i)); // „abfahren" mit der Maus
        m.addEventListener('focus', () => show(i));      // Tastatur
        m.addEventListener('click', () => show(i));      // Touch
      });

      // Startzustand: erste Station, ohne Fade
      lockHeight();
      active = 0;
      markers[0].setAttribute('data-active', '');
      titleEl.textContent = stationen[0].jahr + ' · ' + stationen[0].titel;
      textEl.textContent = stationen[0].text;
      requestAnimationFrame(() => { updateFill(0); updateConnector(0); });
      window.addEventListener('resize', () => {
        lockHeight();
        // Inhalt der aktiven Station nach dem Messen wiederherstellen
        titleEl.textContent = stationen[active].jahr + ' · ' + stationen[active].titel;
        textEl.textContent = stationen[active].text;
        updateFill(active);
        updateConnector(active);
      });
    })();
  </script>

</BaseLayout>
