          <div class="flex items-center gap-1.5 mb-5">
            <span class="live-dot w-2 h-2 rounded-full shrink-0" style="background:#ccc;"></span>
            <span class="live-label text-xs font-medium" style="color:#999;">Aktuell geschlossen</span>
          </div>
          <p class="text-xs font-semibold tracking-widest uppercase text-[#92400E] mb-4">Infekt-Sprechstunde</p>
          <div class="space-y-1">
            <div class="flex justify-between gap-4 text-base text-[#92400E]"><span>Mo–Do</span><span class="tabular-nums">11:00–12:00 Uhr</span></div>
          </div>
          <p class="text-sm text-[#92400E] mt-3">Nur mit FFP2-Maske.<br/>Kein Termin buchbar.</p>
        </div>
      </div>

      <!-- Betriebsferien + Notfallvertretung nebeneinander -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">

        <div class="bg-white rounded-2xl p-8">
          <p class="text-xs font-semibold tracking-widest uppercase text-[#86868B] mb-5">Betriebsferien</p>
          <div id="ferien-list" class="space-y-3">
            {betriebsferien.map(f => (
              <div class="ferien-row flex justify-between text-sm border-b border-[#E8E8ED] pb-3" data-end={f.end}>
                <span class="text-[#1D1D1F]">{f.label}</span>
                <span class="text-[#6E6E73]">{f.display}</span>
              </div>
            ))}
            <p id="ferien-empty" class="hidden text-sm text-[#6E6E73]">Aktuell sind keine Betriebsferien geplant.</p>
