  </section>

  <!-- ═══════════════════════════════════════════
       ÖFFNUNGSZEITEN
  ═══════════════════════════════════════════ -->
  <section id="zeiten" class="bg-[#F5F5F7] py-24">
    <div class="max-w-6xl mx-auto px-6">
      <p class="text-sm font-semibold tracking-widest uppercase text-[#922c37] mb-4">Sprechzeiten</p>
      <h2 class="text-4xl font-semibold tracking-tight text-[#1D1D1F] mb-10">Wann wir für Sie da sind.</h2>

      <!-- Sprechzeiten-Karten mit Live-Status -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">

        <!-- Termin-Sprechstunde -->
        <div class="hours-card bg-white rounded-2xl p-8 flex flex-col">
          <div class="flex items-center gap-1.5 mb-5">
            <span class="live-dot w-2 h-2 rounded-full shrink-0" style="background:#ccc;"></span>
            <span class="live-label text-xs font-medium" style="color:#999;">Aktuell geschlossen</span>
          </div>
          <p class="text-xs font-semibold tracking-widest uppercase text-[#86868B] mb-4">Termin-Sprechstunde</p>
          <div class="space-y-1">
            <div class="flex justify-between gap-4 text-base text-[#1D1D1F]"><span>Mo–Fr</span><span class="tabular-nums">08:30–10:00 Uhr</span></div>
            <div class="flex justify-between gap-4 text-base text-[#1D1D1F]"><span>Mo, Di, Do</span><span class="tabular-nums">16:00–17:00 Uhr</span></div>
          </div>
          <a
            href="https://www.doctolib.de/allgemeinarzt/krefeld/frank-van-dinther"
            target="_blank"
            rel="noopener"
            class="mt-4 text-sm font-medium text-[#922c37] hover:underline"
          >
            Termin buchen via Doctolib →
          </a>
        </div>

        <!-- Ohne Termin -->
        <div class="hours-card bg-white rounded-2xl p-8">
          <div class="flex items-center gap-1.5 mb-5">
            <span class="live-dot w-2 h-2 rounded-full shrink-0" style="background:#ccc;"></span>
            <span class="live-label text-xs font-medium" style="color:#999;">Aktuell geschlossen</span>
          </div>
          <p class="text-xs font-semibold tracking-widest uppercase text-[#86868B] mb-4">Freie Sprechstunde</p>
          <div class="space-y-1">
            <div class="flex justify-between gap-4 text-base text-[#1D1D1F]"><span>Mo–Fr</span><span class="tabular-nums">10:00–11:00 Uhr</span></div>
            <div class="flex justify-between gap-4 text-base text-[#1D1D1F]"><span>Mo, Di, Do</span><span class="tabular-nums">17:00–18:00 Uhr</span></div>
