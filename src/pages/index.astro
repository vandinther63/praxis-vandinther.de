---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Praxis van Dinther"
  description="Facharzt für Allgemeinmedizin in Krefeld. Termin online buchen über Doctolib."
>

  <!-- ═══════════════════════════════════════════
       HERO
  ═══════════════════════════════════════════ -->
  <section id="start" class="hero" style="background:#1a0608;position:relative;overflow:hidden;margin-top:-64px;padding-top:64px;">
    <canvas id="hero-canvas" aria-hidden="true" style="position:absolute;inset:0;width:100%;height:100%;display:block;"></canvas>

