            href="https://www.doctolib.de/allgemeinarzt/krefeld/frank-van-dinther"
            target="_blank"
            rel="noopener"
            class="inline-flex items-center justify-center rounded-full px-8 py-3.5 text-base font-medium transition-colors"
            style="background:#fff;color:#922c37;"
