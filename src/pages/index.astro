        <button id="close-form-modal" type="button" aria-label="Schließen" class="absolute top-5 right-5 w-9 h-9 rounded-full bg-[#F5F5F7] hover:bg-[#E8E8ED] flex items-center justify-center transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#1D1D1F" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18M6 6l12 12"/></svg>
        </button>

        <p class="text-sm font-semibold tracking-widest uppercase text-[#922c37] mb-3">Kontaktformular</p>
        <h2 id="form-modal-title" class="text-2xl font-semibold tracking-tight text-[#1D1D1F] mb-3">Schreiben Sie uns.</h2>
        <p class="text-sm text-[#6E6E73] leading-relaxed mb-7">
          Schneller als ein Anruf: Schildern Sie Ihr Anliegen in Ruhe, wir bearbeiten es gesammelt und melden uns innerhalb von 1–2 Werktagen — ohne Warteschleife.
        </p>

        <form id="contact-form" class="flex flex-col gap-5 w-full" novalidate>

          <!-- Betreff -->
          <div class="ff-field">
            <select id="betreff" name="betreff" required class="ff-input ff-select peer">
              <option value="" disabled selected hidden></option>
              <option value="rezept">Rezept-Anfrage</option>
              <option value="ueberweisung">Überweisung</option>
              <option value="neupatient">Anfrage als Neupatient:in</option>
              <option value="befund">Befund-Rückfrage</option>
              <option value="sonstiges">Sonstiges</option>
            </select>
            <label for="betreff" class="ff-label ff-label-fixed">Ihr Anliegen *</label>
            <div class="pointer-events-none absolute inset-y-0 right-4 flex items-center">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#86868B" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
            </div>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            <div class="ff-field">
              <input type="text" id="name" name="name" required autocomplete="name" placeholder=" " class="ff-input peer" />
              <label for="name" class="ff-label">Name *</label>
            </div>
            <div class="ff-field">
              <input type="date" id="geburtsdatum" name="geburtsdatum" autocomplete="bday" class="ff-input ff-date peer" />
              <label for="geburtsdatum" class="ff-label ff-label-fixed">Geburtsdatum</label>
            </div>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            <div class="ff-field">
              <input type="tel" id="telefon" name="telefon" required autocomplete="tel" placeholder=" " class="ff-input peer" />
              <label for="telefon" class="ff-label">Telefon *</label>
            </div>
            <div class="ff-field">
              <input type="email" id="email" name="email" autocomplete="email" placeholder=" " class="ff-input peer" />
              <label for="email" class="ff-label">E-Mail</label>
            </div>
          </div>

          <div class="ff-field">
            <textarea id="nachricht" name="nachricht" required placeholder=" " class="ff-input peer resize-none w-full min-h-[120px]"></textarea>
            <label for="nachricht" class="ff-label">Nachricht *</label>
          </div>

          <p class="text-xs text-[#86868B] leading-relaxed">
            Mit dem Absenden stimmen Sie der Verarbeitung Ihrer Daten zur Bearbeitung Ihrer Anfrage zu. Weitere Informationen in unserer <a href="/datenschutz" class="text-[#922c37] hover:underline">Datenschutzerklärung</a>.
          </p>

          <button type="submit" id="submit-btn" disabled class="bg-[#922c37] text-white rounded-full px-10 py-3.5 text-base font-medium hover:bg-[#7a2430] transition-colors disabled:opacity-40 disabled:cursor-not-allowed self-start">
            Nachricht senden
          </button>

          <div id="form-success" class="hidden bg-[#F0FAF4] border border-[#4ADE80] rounded-xl p-5">
            <p class="text-sm font-medium text-[#166534]">Vielen Dank — Ihre Nachricht ist bei uns eingegangen. Wir melden uns innerhalb von 1–2 Werktagen bei Ihnen.</p>
          </div>
          <div id="form-error" class="hidden bg-[#FEF2F2] border border-[#EF4444] rounded-xl p-5">
            <p class="text-sm font-medium text-[#991B1B]">Es ist ein Fehler aufgetreten. Bitte versuchen Sie es erneut oder rufen Sie uns an: <a href="tel:021514789890" class="underline">02151 478989</a></p>
          </div>

        </form>
      </div>
    </div>
  </div>

  <style>
    /* Floating-Label Felder */
    .ff-field { position: relative; }
    .ff-input {
      width: 100%;
      background: #fff;
      border: 1px solid #E8E8ED;
      border-radius: 0.75rem;
      padding: 1.4rem 1rem 0.5rem 1rem;
      font-size: 1rem;
      color: #1D1D1F;
      transition: border-color 0.15s;
      appearance: none;
    }
    .ff-input:focus { outline: none; border-color: #922c37; }
    .ff-select { cursor: pointer; }
    .ff-label {
      position: absolute;
      left: 1rem;
      top: 50%;
      transform: translateY(-50%);
      font-size: 1rem;
      color: #86868B;
      pointer-events: none;
      transition: all 0.15s ease;
      background: transparent;
    }
    /* Floated state: when filled (not placeholder-shown) or focused */
    .ff-input:focus ~ .ff-label,
    .ff-input:not(:placeholder-shown) ~ .ff-label,
    .ff-label-fixed {
      top: 0.5rem;
      transform: translateY(0);
      font-size: 0.7rem;
      letter-spacing: 0.03em;
    }
    .ff-input:focus ~ .ff-label { color: #922c37; }
    /* Textarea label sits at top, not centered */
    textarea.ff-input ~ .ff-label { top: 1.1rem; transform: none; }
    textarea.ff-input:focus ~ .ff-label,
    textarea.ff-input:not(:placeholder-shown) ~ .ff-label { top: 0.5rem; }
  </style>

  <script>
    // Modal open/close
    const modal = document.getElementById('form-modal');
    const openBtn = document.getElementById('open-form-modal');
    const closeBtn = document.getElementById('close-form-modal');
    const backdrop = document.getElementById('form-backdrop');
    function openModal() {
      if (!modal) return;
      modal.classList.remove('hidden');
      modal.classList.add('modal-enter');
      // nächster Frame: Zielzustand → CSS-Transition läuft
      requestAnimationFrame(() => modal.classList.remove('modal-enter'));
      document.body.style.overflow = 'hidden';
      (document.getElementById('betreff') as HTMLElement)?.focus();
    }
    function closeModal() {
      if (!modal) return;
      modal.classList.add('modal-enter'); // zurück in den Anfangszustand (exit)
      document.body.style.overflow = '';
      setTimeout(() => {
        modal.classList.add('hidden');
        modal.classList.remove('modal-enter');
      }, 160);
      openBtn?.focus();
    }
    openBtn?.addEventListener('click', openModal);
    closeBtn?.addEventListener('click', closeModal);
    backdrop?.addEventListener('click', closeModal);
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && modal && !modal.classList.contains('hidden')) closeModal();
    });

    const form = document.getElementById('contact-form') as HTMLFormElement;
    const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
    const successEl = document.getElementById('form-success')!;
    const errorEl = document.getElementById('form-error')!;

    // Disable submit until required fields are filled
    const requiredFields = form?.querySelectorAll('[required]');
    function checkForm() {
      if (!form || !submitBtn) return;
      const allFilled = Array.from(requiredFields || []).every(f => {
        const el = f as HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement;
        return el.value.trim() !== '';
      });
      submitBtn.disabled = !allFilled;
    }
    requiredFields?.forEach(f => f.addEventListener('input', checkForm));
    requiredFields?.forEach(f => f.addEventListener('change', checkForm));
    checkForm();

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!form.checkValidity()) { form.reportValidity(); return; }

      submitBtn.disabled = true;
      submitBtn.textContent = 'Wird gesendet …';
      successEl.classList.add('hidden');
      errorEl.classList.add('hidden');

      try {
        const res = await fetch('/api/contact', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(Object.fromEntries(new FormData(form))),
        });
        if (res.ok) {
          successEl.classList.remove('hidden');
          form.reset();
        } else {
          errorEl.classList.remove('hidden');
        }
      } catch {
        errorEl.classList.remove('hidden');
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = 'Nachricht senden';
      }
    });
  </script>

  <style>
    .cta-card {
      background: linear-gradient(to right, #922c37, #c04050);
    }
    .cta-card:hover {
      background: linear-gradient(to right, #7a2430, #a03040);
    }

    /* Modal Enter/Exit — Panel scalt aus der Mitte, Backdrop faded */
    .modal-backdrop { transition: opacity 200ms var(--ease-out); }
    .modal-panel {
      transition: transform 200ms var(--ease-out), opacity 200ms var(--ease-out);
    }
    #form-modal.modal-enter .modal-backdrop { opacity: 0; }
    #form-modal.modal-enter .modal-panel {
      opacity: 0;
      transform: scale(0.96) translateY(8px);
    }
    @media (prefers-reduced-motion: reduce) {
      .modal-panel { transform: none !important; }
    }
  </style>

  <script>
    // Smooth accordion open/close via WAAPI — gilt für alle <details> (Leistungen + Wissen)
    (function () {
      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const EASE = 'cubic-bezier(0.23, 1, 0.32, 1)';

      document.querySelectorAll('details').forEach((el) => {
        const details = el as HTMLDetailsElement;
        const summary = details.querySelector('summary');
        // Inhalt = alles nach dem summary in einen Wrapper packen
        const body = details.querySelector('summary')?.nextElementSibling as HTMLElement | null;
        if (!summary || !body) return;

        let current: Animation | null = null;

        summary.addEventListener('click', (e) => {
          if (reduce) return; // native Verhalten bei reduced-motion
          e.preventDefault();

          // Laufende Animation sauber abbrechen (interruptierbar)
          if (current) { current.cancel(); current = null; }

          // overflow während der Animation hart kappen, damit nichts überquillt
          body.style.overflow = 'hidden';

          if (!details.open) {
            // ÖFFNEN
            details.open = true;
            const h = body.scrollHeight;
            current = body.animate(
              [
                { height: '0px', opacity: 0 },
                { height: h + 'px', opacity: 1 },
              ],
              { duration: 240, easing: EASE }
            );
            current.onfinish = () => {
              body.style.overflow = '';   // natürliche Höhe wiederherstellen
              current = null;
            };
          } else {
            // SCHLIESSEN — von echter aktueller Höhe auf 0
            const h = body.getBoundingClientRect().height;
            current = body.animate(
              [
                { height: h + 'px', opacity: 1 },
                { height: '0px', opacity: 0 },
              ],
              { duration: 200, easing: EASE, fill: 'forwards' }
            );
            current.onfinish = () => {
              details.open = false;        // erst NACH der Animation einklappen
              body.style.overflow = '';
              current?.cancel();            // forwards-fill lösen
              current = null;
            };
          }
        });
      });
    })();
  </script>

</BaseLayout>
