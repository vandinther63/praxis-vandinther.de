---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Praxis van Dinther" description="Facharzt für Allgemeinmedizin in Krefeld. Terminbuchung online über Doctolib.">

  <!-- Hero -->
  <section class="relative overflow-hidden bg-white">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_30%_60%,_#EBF2FF_0%,_transparent_60%)] pointer-events-none"></div>
    <div class="absolute inset-0 flex items-center justify-center pointer-events-none select-none overflow-hidden">
      <span class="text-[200px] lg:text-[320px] font-black text-[#F5F5F7] leading-none tracking-tighter whitespace-nowrap">
        van Dinther
      </span>
    </div>
    <div class="relative max-w-6xl mx-auto px-6 py-32 lg:py-48">
      <p class="text-sm font-semibold tracking-widest uppercase text-[#0071E3] mb-6">Krefeld · Allgemeinmedizin</p>
      <h1 class="text-5xl lg:text-7xl font-semibold tracking-tight text-[#1D1D1F] max-w-2xl leading-tight mb-6">
        Ihre Hausarzt&shy;praxis in Krefeld.
      </h1>
      <p class="text-lg lg:text-xl text-[#6E6E73] max-w-xl leading-relaxed mb-10">
        Frank van Dinther, Facharzt für Allgemeinmedizin. Termine online buchbar — auch als Videosprechstunde.
      </p>
      <div class="flex flex-col sm:flex-row gap-4">
        <a
          href="https://www.doctolib.de/allgemeinarzt/krefeld/frank-van-dinther"
          target="_blank"
          rel="noopener"
          class="inline-flex items-center justify-center bg-[#0071E3] text-white rounded-full px-8 py-3.5 text-base font-medium hover:bg-[#0058B0] transition-colors"
        >
          Termin online vereinbaren
        </a>
        <a
          href="/kontakt"
          class="inline-flex items-center justify-center bg-[#F5F5F7] text-[#1D1D1F] rounded-full px-8 py-3.5 text-base font-medium hover:bg-[#E8E8ED] transition-colors"
        >
          Kontakt aufnehmen
        </a>
      </div>
    </div>
  </section>

  <!-- Trust bar -->
  <section class="border-y border-[#E8E8ED]">
    <div class="max-w-6xl mx-auto px-6 py-8">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:divide-x divide-[#E8E8ED]">
        <div class="md:pr-6">
          <p class="text-xs font-semibold tracking-widest uppercase text-[#86868B] mb-1">Ausbildung</p>
          <p class="text-sm text-[#1D1D1F]">Akademische Lehrpraxis · HHU Düsseldorf</p>
        </div>
        <div class="md:px-6">
          <p class="text-xs font-semibold tracking-widest uppercase text-[#86868B] mb-1">Weiterbildung</p>
          <p class="text-sm text-[#1D1D1F]">Weiterbildungspraxis · Ärztekammer Nordrhein</p>
        </div>
        <div class="md:pl-6">
          <p class="text-xs font-semibold tracking-widest uppercase text-[#86868B] mb-1">Fachgebiet</p>
          <p class="text-sm text-[#1D1D1F]">Facharzt für Allgemeinmedizin · Chirotherapie</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Quick access bento -->
  <section class="max-w-6xl mx-auto px-6 py-24">
    <p class="text-sm font-semibold tracking-widest uppercase text-[#0071E3] mb-4">Schnellzugriff</p>
    <h2 class="text-4xl font-semibold tracking-tight text-[#1D1D1F] mb-10">Was möchten Sie tun?</h2>
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
      <a
        href="https://www.doctolib.de/allgemeinarzt/krefeld/frank-van-dinther"
        target="_blank"
        rel="noopener"
        class="col-span-2 bg-[#0071E3] rounded-3xl p-10 hover:bg-[#0058B0] transition-colors"
      >
        <p class="text-sm font-semibold text-white/70 tracking-widest uppercase mb-3">Online</p>
        <p class="text-2xl font-semibold text-white tracking-tight">Termin buchen →</p>
        <p class="text-sm text-white/70 mt-2">Auch als Videosprechstunde verfügbar</p>
      </a>
      <a href="/aktuelles" class="bg-[#F5F5F7] rounded-3xl p-8 hover:bg-[#E8E8ED] transition-colors">
        <p class="text-xs font-semibold text-[#86868B] tracking-widest uppercase mb-3">Zeiten</p>
        <p class="text-xl font-semibold text-[#1D1D1F] tracking-tight">Öffnungszeiten</p>
        <p class="text-sm text-[#6E6E73] mt-2">Mo–Fr ab 8:30 Uhr</p>
      </a>
      <a href="/kontakt" class="bg-[#F5F5F7] rounded-3xl p-8 hover:bg-[#E8E8ED] transition-colors">
        <p class="text-xs font-semibold text-[#86868B] tracking-widest uppercase mb-3">Anfragen</p>
        <p class="text-xl font-semibold text-[#1D1D1F] tracking-tight">Kontaktformular</p>
        <p class="text-sm text-[#6E6E73] mt-2">Rezepte, Überweisungen & mehr</p>
      </a>
    </div>
    <div class="mt-4 bg-[#FFF9EB] border border-[#F59E0B] rounded-2xl p-6 flex gap-4">
      <div class="text-[#F59E0B] mt-0.5 shrink-0">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3"/><path d="M12 9v4"/><path d="M12 17h.01"/></svg>
      </div>
      <div>
        <p class="text-sm font-semibold text-[#92400E]">Atemwegsinfekt-Sprechstunde</p>
        <p class="text-sm text-[#92400E] mt-1">Bei Erkältungssymptomen bitte ausschließlich Mo–Do von 11–12 Uhr mit FFP2-Maske kommen. Kein Termin erforderlich.</p>
      </div>
    </div>
  </section>

  <!-- Services preview -->
  <section class="bg-[#F5F5F7] py-24">
    <div class="max-w-6xl mx-auto px-6">
      <p class="text-sm font-semibold tracking-widest uppercase text-[#0071E3] mb-4">Leistungen</p>
      <h2 class="text-4xl font-semibold tracking-tight text-[#1D1D1F] mb-10">Was wir für Sie tun.</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <a href="/leistung#diagnostik" class="bg-white rounded-2xl p-8 hover:shadow-sm transition-shadow group">
          <div class="w-10 h-10 text-[#0071E3] mb-6">
            <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
          </div>
          <h3 class="text-xl font-medium tracking-tight text-[#1D1D1F] mb-2">Diagnostik</h3>
          <p class="text-base text-[#6E6E73] leading-relaxed">Labor, EKG, Langzeitblutdruck, Lungenfunktion und Ultraschall.</p>
          <p class="text-sm font-medium text-[#0071E3] mt-4 group-hover:underline">Mehr erfahren →</p>
        </a>
        <a href="/leistung#vorsorge" class="bg-white rounded-2xl p-8 hover:shadow-sm transition-shadow group">
          <div class="w-10 h-10 text-[#0071E3] mb-6">
            <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12l2 2 4-4"/><path d="M21 12c0 4.97-4.03 9-9 9s-9-4.03-9-9 4.03-9 9-9c1.51 0 2.93.37 4.18 1.03"/><path d="M21 3l-4 4"/><path d="M17 3h4v4"/></svg>
          </div>
          <h3 class="text-xl font-medium tracking-tight text-[#1D1D1F] mb-2">Vorsorge</h3>
          <p class="text-base text-[#6E6E73] leading-relaxed">Krebsvorsorge, Gesundheitschecks, Hautkrebs-Screening und mehr.</p>
          <p class="text-sm font-medium text-[#0071E3] mt-4 group-hover:underline">Mehr erfahren →</p>
        </a>
        <a href="/leistung#igel" class="bg-white rounded-2xl p-8 hover:shadow-sm transition-shadow group">
          <div class="w-10 h-10 text-[#0071E3] mb-6">
            <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
          </div>
          <h3 class="text-xl font-medium tracking-tight text-[#1D1D1F] mb-2">IGeL-Leistungen</h3>
          <p class="text-base text-[#6E6E73] leading-relaxed">Reisemedizin, Sporttauglichkeit, erweiterte Untersuchungen nach GOÄ.</p>
          <p class="text-sm font-medium text-[#0071E3] mt-4 group-hover:underline">Mehr erfahren →</p>
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
