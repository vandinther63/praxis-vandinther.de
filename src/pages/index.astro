            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <script>
  (function(){
    const now = new Date();
    const day = now.getDay(); // 0=So, 1=Mo, ..., 5=Fr, 6=Sa
    const mins = now.getHours() * 60 + now.getMinutes();
    const isWeekday = day >= 1 && day <= 5;
    const isMoDiDo = [1, 2, 4].includes(day);
    const status = {
      termin: isWeekday && (mins >= 510 && mins < 600 || isMoDiDo && mins >= 960 && mins < 1020),
      offen:  isWeekday && (mins >= 600 && mins < 660 || isMoDiDo && mins >= 1020 && mins < 1080),
      infekt: day >= 1 && day <= 4 && mins >= 660 && mins < 720,
    };
    document.querySelectorAll('.hours-card').forEach((card, i) => {
      const key = ['termin','offen','infekt'][i];
      const dot = card.querySelector('.live-dot');
      const label = card.querySelector('.live-label');
      if (!dot || !label) return;
      if (status[key]) {
        dot.style.background = '#22C55E';
        label.textContent = 'Jetzt geöffnet';
        label.style.color = '#16a34a';
      } else {
        dot.style.background = '#ccc';
        label.textContent = 'Aktuell geschlossen';
        label.style.color = '#999';
      }
    });
  })();
  </script>

