      <!-- Externe Links — immer sichtbar -->
      <div class="pt-4 flex flex-wrap gap-3">
        {[
          { href: 'https://www.rauchfrei-info.de', label: 'rauchfrei-info.de' },
          { href: 'https://www.arztsuche-nordrhein.de', label: 'Arztsuche Nordrhein' },
          { href: 'https://www.kbv.de/html/patienteninformationen.php', label: 'KBV Patienteninformationen' },
        ].map(({ href, label }) => (
          <a href={href} target="_blank" rel="noopener" class="inline-flex items-center gap-2 bg-[#F5F5F7] hover:bg-[#E8E8ED] text-[#6E6E73] hover:text-[#1D1D1F] rounded-full px-5 py-2.5 text-sm transition-colors">
