      <div class="grid grid-cols-1 lg:grid-cols-3 gap-4 items-stretch">
        <div class="lg:col-span-2 rounded-2xl overflow-hidden min-h-[280px]">
          <iframe
            src="https://maps.google.com/maps?q=Neukirchener+Stra%C3%9Fe+5,+47829+Krefeld&output=embed&hl=de&z=16"
            width="100%"
            height="100%"
            style="border:0;display:block;height:100%;min-height:280px;"
            loading="lazy"
            allowfullscreen
            referrerpolicy="no-referrer-when-downgrade"
            title="Karte: Praxis van Dinther, Neukirchener Straße 5, Krefeld"
          ></iframe>
        </div>
        <div class="bg-[#F5F5F7] rounded-2xl p-8 flex flex-col">
          <p class="text-base font-medium text-[#1D1D1F]">Praxis van Dinther</p>
          <p class="text-sm text-[#6E6E73] mt-1">Neukirchener Straße 5<br/>47829 Krefeld</p>
          <p class="text-sm text-[#86868B] mt-4">Straßenbahn 042 / Bus 058<br/>Haltestelle: Neukirchener Straße</p>
          <a
            href="https://www.google.com/maps/dir/?api=1&destination=Neukirchener+Stra%C3%9Fe+5%2C+47829+Krefeld"
            target="_blank"
