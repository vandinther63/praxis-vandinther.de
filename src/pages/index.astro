---
import BaseLayout from '../layouts/BaseLayout.astro';

// Betriebsferien — `end` ist das letzte Tag der Schließung (ISO YYYY-MM-DD).
// Einträge, deren Enddatum vorbei ist, werden im Browser automatisch ausgeblendet;
// angezeigt werden immer nur die nächsten 3. Neue Termine einfach hier ergänzen.
const betriebsferien = [
  { label: 'Brückentag',   display: '05. Juni 2026',         end: '2026-06-05' },
  { label: 'Sommerurlaub', display: '03.–18. August 2026',   end: '2026-08-18' },
  { label: 'Jahreswechsel', display: '18.–31. Dezember 2026', end: '2026-12-31' },
].sort((a, b) => a.end.localeCompare(b.end));
---

<BaseLayout
  title="Praxis van Dinther"
  description="Facharzt für Allgemeinmedizin in Krefeld. Termin online buchen über Doctolib."
>

  <!-- ═══════════════════════════════════════════
       HERO
  ═══════════════════════════════════════════ -->
  <section id="start" class="hero" style="background:#1a0608;position:relative;overflow:hidden;margin-top:-64px;padding-top:64px;">
    <canvas id="hero-canvas" aria-hidden="true" style="position:absolute;inset:0;width:100%;height:100%;display:block;"></canvas>

    <div style="position:relative;z-index:1;" class="max-w-6xl mx-auto px-6 pt-20 pb-16 lg:pt-28 lg:pb-20 flex flex-col lg:flex-row lg:items-end lg:justify-between gap-12">
      <div class="max-w-2xl">
        <div class="w-10 h-[3px] mb-8 rounded-full" style="background:rgba(255,255,255,0.5);"></div>
        <p class="text-sm font-semibold tracking-widest uppercase mb-5" style="color:rgba(255,255,255,0.6);">
          Krefeld · Allgemeinmedizin
        </p>
        <h1 class="text-5xl lg:text-7xl font-semibold tracking-tight leading-[1.05] mb-6" style="color:#fff;">
          Ihre Hausarzt&shy;praxis in Krefeld.
        </h1>
        <p class="text-lg lg:text-xl leading-relaxed mb-10 max-w-lg" style="color:rgba(255,255,255,0.7);">
          Frank van Dinther, Facharzt für Allgemeinmedizin.
          Am schnellsten erreichen Sie uns über Doctolib.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a
            href="https://www.doctolib.de/allgemeinarzt/krefeld/frank-van-dinther"
            target="_blank"
            rel="noopener"
            class="inline-flex items-center justify-center rounded-full px-8 py-3.5 text-base font-medium transition-colors"
            style="background:#fff;color:#922c37;"
            onmouseover="this.style.background='rgba(255,255,255,0.9)'"
            onmouseout="this.style.background='#fff'"
