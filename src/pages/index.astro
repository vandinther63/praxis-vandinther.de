  <script>
  (function(){
    const canvas = document.getElementById("hero-canvas");
    if (!canvas) return;
    const ctx = canvas.getContext("2d");
    let t = 0, raf, W, H;

    function resize() {
      const dpr = Math.min(window.devicePixelRatio || 1, 2);
      W = canvas.offsetWidth;
      H = canvas.offsetHeight;
      canvas.width = W * dpr;
      canvas.height = H * dpr;
      ctx.scale(dpr, dpr);
    }

    function blob(cx, cy, rx, ry, pts, phase, speed) {
      const p = [];
      for (let i = 0; i < pts; i++) {
        const a = (i / pts) * Math.PI * 2;
        const d =
          Math.sin(a * 2 + t * speed + phase) * 0.31 +
          Math.cos(a * 3 + t * speed * 0.65 + phase * 1.4) * 0.18 +
          Math.sin(a * 7 + t * speed * 0.28) * 0.07;
        p.push({ x: cx + Math.cos(a) * rx * (1 + d), y: cy + Math.sin(a) * ry * (1 + d) });
      }
      const n = p.length;
      ctx.beginPath();
      ctx.moveTo((p[n-1].x + p[0].x)/2, (p[n-1].y + p[0].y)/2);
      for (let i = 0; i < n; i++) {
        const c = p[i], nx = p[(i+1)%n];
        ctx.quadraticCurveTo(c.x, c.y, (c.x+nx.x)/2, (c.y+nx.y)/2);
      }
      ctx.closePath();
    }

    function rgrad(cx, cy, r, inner, outer) {
      const g = ctx.createRadialGradient(cx, cy, 0, cx, cy, r);
      g.addColorStop(0, inner);
      g.addColorStop(1, outer);
      return g;
    }

    function draw() {
      // Background — dark bordeaux (was #0d1a10 dark green)
      ctx.fillStyle = "#1a0608";
      ctx.fillRect(0, 0, W, H);
      ctx.globalCompositeOperation = "screen";

      // Orb 1 — main bordeaux (was #2e6842 mid-green)
      ctx.globalAlpha = 0.65;
      blob(W*.22, H*.52, W*.44, H*.52, 14, 0, .12);
      ctx.fillStyle = rgrad(W*.22, H*.52, W*.44, "#922c37", "#1a0608");
      ctx.fill();

      // Orb 2 — dark bordeaux (was #245238 dark green)
      ctx.globalAlpha = 0.55;
      blob(W*.74, H*.42, W*.36, H*.44, 12, 2.1, .17);
      ctx.fillStyle = rgrad(W*.74, H*.42, W*.36, "#7a2430", "#120407");
      ctx.fill();

      // Orb 3 — rose highlight (was #3a7a52 lighter green)
      ctx.globalAlpha = 0.45;
      blob(W*.5, H*.82, W*.3, H*.32, 10, 4.4, .22);
      ctx.fillStyle = rgrad(W*.5, H*.82, W*.3, "#c45a65", "#1a0608");
      ctx.fill();

      // Orb 4 — warm pale rose (was #c8a050 golden)
      ctx.globalAlpha = 0.35;
      blob(W*.68, H*.2, W*.22, H*.26, 10, 1, .14);
      ctx.fillStyle = rgrad(W*.68, H*.2, W*.22, "#e8a0a8", "#3a0810");
      ctx.fill();

      // Orb 5 — deep bordeaux shadow (was #1a4028 dark green)
      ctx.globalAlpha = 0.4;
      blob(W*.12, H*.18, W*.28, H*.3, 10, 3.2, .1);
      ctx.fillStyle = rgrad(W*.12, H*.18, W*.28, "#5a1520", "#0a0305");
      ctx.fill();

      // Orb 6 — warm bordeaux tone (was hsl(35,60%,30%) warm amber)
      ctx.globalAlpha = 0.28;
      blob(W*.35, H*.65, W*.26, H*.3, 11, 5.5, .09);
      ctx.fillStyle = rgrad(W*.35, H*.65, W*.26, "hsl(350,60%,30%)", "hsl(350,60%,8%)");
      ctx.fill();

      ctx.globalCompositeOperation = "source-over";
      ctx.globalAlpha = 1;
      t += 0.004;
      raf = requestAnimationFrame(draw);
    }

    window.addEventListener("resize", resize);
    resize();
    draw();
    document.addEventListener("visibilitychange", () => {
      if (document.hidden) cancelAnimationFrame(raf);
      else draw();
    });
  })();
  </script>



  <!-- ═══════════════════════════════════════════
       KONTAKT-HIERARCHIE (Herzstück der Seite)
  ═══════════════════════════════════════════ -->
  <section id="kontakt" class="max-w-6xl mx-auto px-6 py-24">
