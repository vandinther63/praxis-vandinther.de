            Termin buchen
          </a>
          <a
            href="#kontakt"
            class="inline-flex items-center justify-center rounded-full px-8 py-3.5 text-base font-medium transition-colors backdrop-blur-sm"
            style="background:rgba(255,255,255,0.12);color:#fff;border:1px solid rgba(255,255,255,0.25);"
            onmouseover="this.style.background='rgba(255,255,255,0.22)'"
            onmouseout="this.style.background='rgba(255,255,255,0.12)'"
          >
            Kontakt aufnehmen
          </a>
        </div>
      </div>
      <div class="hidden lg:block text-right shrink-0 pb-2">
        <p class="text-[11rem] font-black leading-none tracking-tighter select-none" style="color:rgba(255,255,255,0.08);" aria-hidden="true">vD</p>
        <p class="text-sm tracking-widest uppercase select-none" style="color:rgba(255,255,255,0.15);" aria-hidden="true">Praxis · Krefeld</p>
      </div>
    </div>

    <!-- Trust bar — Frosted Glass innerhalb der Hero-Sektion -->
    <div style="position:relative;z-index:1;border-top:1px solid rgba(255,255,255,0.12);">
      <div style="background:rgba(255,255,255,0.07);backdrop-filter:blur(16px);-webkit-backdrop-filter:blur(16px);">
        <div class="max-w-6xl mx-auto px-6 py-8">
          <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <div class="md:pr-6">
              <p class="text-xs font-semibold tracking-widest uppercase mb-1" style="color:rgba(255,255,255,0.45);">Ausbildung</p>
              <p class="text-sm" style="color:rgba(255,255,255,0.85);">Akademische Lehrpraxis · HHU Düsseldorf</p>
            </div>
            <div class="md:px-6" style="border-left:1px solid rgba(255,255,255,0.15);">
              <p class="text-xs font-semibold tracking-widest uppercase mb-1" style="color:rgba(255,255,255,0.45);">Weiterbildung</p>
              <p class="text-sm" style="color:rgba(255,255,255,0.85);">Weiterbildungspraxis · Ärztekammer Nordrhein</p>
            </div>
            <div class="md:pl-6" style="border-left:1px solid rgba(255,255,255,0.15);">
              <p class="text-xs font-semibold tracking-widest uppercase mb-1" style="color:rgba(255,255,255,0.45);">Fachgebiet</p>
              <p class="text-sm" style="color:rgba(255,255,255,0.85);">Facharzt für Allgemeinmedizin · Chirotherapie</p>
            </div>
