                <p class="text-sm text-[#1D1D1F] group-hover/item:text-[#922c37] transition-colors">{label}</p>
                <span class="text-xs font-medium text-[#86868B] bg-white rounded-full px-3 py-1 shrink-0 ml-4 group-hover/item:text-[#922c37] transition-colors">PDF ↓</span>
              </a>
            ))}
          </div>
        </div>
      </details>

      <!-- 3. Früherkennung & Vorsorge -->
      <details class="group bg-[#F5F5F7] rounded-2xl overflow-hidden">
        <summary class="flex items-center justify-between px-8 py-5 cursor-pointer list-none select-none">
          <div class="flex items-center gap-4">
            <span class="w-8 h-8 rounded-xl bg-white flex items-center justify-center shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#922c37" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
            </span>
            <span class="text-base font-medium text-[#1D1D1F]">Früherkennung & Vorsorge</span>
          </div>
          <svg class="w-5 h-5 text-[#86868B] transition-transform duration-200 group-open:rotate-180" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
        </summary>
        <div class="px-8 pb-7 border-t border-[#E8E8ED]">
          <div class="pt-5 space-y-3">
            {[
              { label: 'Früherkennung Bauchaortenaneurysma', file: '/patienteninfo/frueerkennung_aneurysma.pdf' },
              { label: 'Früherkennung Hautkrebs', file: '/patienteninfo/hautkrebspraevention-kip.pdf' },
              { label: 'Früherkennung Darmkrebs', file: '/patienteninfo/darmkrebs-frueherkennung-kip.pdf' },
              { label: 'Früherkennung Prostatakrebs', file: '/patienteninfo/prostata-frueherkennung-kip.pdf' },
            ].map(({ label, file }) => (
              <a href={file} target="_blank" rel="noopener" class="flex items-center justify-between py-3 border-b border-[#E8E8ED] group/item hover:border-[#922c37] transition-colors">
                <p class="text-sm text-[#1D1D1F] group-hover/item:text-[#922c37] transition-colors">{label}</p>
                <span class="text-xs font-medium text-[#86868B] bg-white rounded-full px-3 py-1 shrink-0 ml-4 group-hover/item:text-[#922c37] transition-colors">PDF ↓</span>
              </a>
            ))}
          </div>
        </div>
      </details>

      <!-- 4. Medikamente & Allgemein -->
      <details class="group bg-[#F5F5F7] rounded-2xl overflow-hidden">
        <summary class="flex items-center justify-between px-8 py-5 cursor-pointer list-none select-none">
          <div class="flex items-center gap-4">
            <span class="w-8 h-8 rounded-xl bg-white flex items-center justify-center shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#922c37" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="m10.5 20.5 10-10a4.95 4.95 0 1 0-7-7l-10 10a4.95 4.95 0 1 0 7 7z"/><path d="M8.5 8.5 16 16"/></svg>
            </span>
            <span class="text-base font-medium text-[#1D1D1F]">Medikamente & Allgemeines</span>
          </div>
          <svg class="w-5 h-5 text-[#86868B] transition-transform duration-200 group-open:rotate-180" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
        </summary>
        <div class="px-8 pb-7 border-t border-[#E8E8ED]">
          <div class="pt-5 space-y-3">
            {[
              { label: 'Was hilft bei Erkältungshusten', file: '/patienteninfo/053-013p_S3_Husten_2014-02-verlaengert.pdf' },
              { label: 'Nahrungsergänzungsmittel — was Experten empfehlen', file: '/patienteninfo/Nahrungsaergaenzung.pdf' },
              { label: 'Ernährung unter Marcumar-Therapie', file: null },
              { label: 'Multiresistente Erreger (MRSA)', file: '/patienteninfo/Pat_Info_MRSA.pdf' },
              { label: 'Multimedikation — mehr als 5 Medikamente', file: '/patienteninfo/Pat_Info_Multimedikation.pdf' },
              { label: 'Häusliche Isolierung bei COVID-19', file: '/patienteninfo/haeusliche_Isolierung.pdf' },
            ].map(({ label, file }) => (
              file ? (
                <a href={file} target="_blank" rel="noopener" class="flex items-center justify-between py-3 border-b border-[#E8E8ED] group/item hover:border-[#922c37] transition-colors">
                  <p class="text-sm text-[#1D1D1F] group-hover/item:text-[#922c37] transition-colors">{label}</p>
                  <span class="text-xs font-medium text-[#86868B] bg-white rounded-full px-3 py-1 shrink-0 ml-4 group-hover/item:text-[#922c37] transition-colors">PDF ↓</span>
                </a>
              ) : (
                <div class="flex items-center gap-3 py-3 border-b border-[#E8E8ED]">
