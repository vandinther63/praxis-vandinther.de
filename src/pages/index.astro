  <script>
  (function(){
    const now = new Date();
    const day = now.getDay(); // 0=So, 1=Mo, ..., 5=Fr, 6=Sa
    const mins = now.getHours() * 60 + now.getMinutes();
    const isWeekday = day >= 1 && day <= 5;
    const isMoDiDo = [1, 2, 4].includes(day);
    const status = {
      termin: isWeekday && (mins >= 510 && mins < 600 || isMoDiDo && mins >= 960 && mins < 1020),
      offen:  isWeekday && (mins >= 600 && mins < 660 || isMoDiDo && mins >= 1020 && mins < 1080),
      infekt: day >= 1 && day <= 4 && mins >= 660 && mins < 720,
    };
    document.querySelectorAll('.hours-card').forEach((card, i) => {
      const key = ['termin','offen','infekt'][i];
      const dot = card.querySelector('.live-dot');
      const label = card.querySelector('.live-label');
      if (!dot || !label) return;
      if (status[key]) {
        dot.style.background = '#22C55E';
        label.textContent = 'Jetzt geöffnet';
        label.style.color = '#16a34a';
      } else {
        dot.style.background = '#ccc';
        label.textContent = 'Aktuell geschlossen';
        label.style.color = '#999';
      }
    });
  })();
  </script>

  <!-- Betriebsferien: vergangene ausblenden, nur die nächsten 3 zeigen -->
  <script>
  (function () {
    const list = document.getElementById('ferien-list');
    if (!list) return;
    const empty = document.getElementById('ferien-empty');
    const rows = Array.from(list.querySelectorAll('.ferien-row'));
    const today = new Date();
    today.setHours(0, 0, 0, 0);

    // nur Einträge, deren Enddatum heute oder in der Zukunft liegt
    const upcoming = rows.filter((r) => {
      const end = new Date(r.dataset.end + 'T23:59:59');
      return end >= today;
    });

    rows.forEach((r) => { r.style.display = 'none'; });

    const visible = upcoming.slice(0, 3);
    visible.forEach((r, i) => {
      r.style.display = '';
      // letzte sichtbare Zeile ohne Trennlinie
      r.classList.toggle('border-b', i < visible.length - 1);
      r.classList.toggle('pb-3', i < visible.length - 1);
    });

    if (empty) empty.classList.toggle('hidden', visible.length > 0);
  })();
  </script>

